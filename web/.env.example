# Ship Web - Local Development Configuration
# Copy this to .env and customize values:
#   cp .env.example .env

# Application environment
# Values: development, test_e2e, production
VITE_APP_ENV=development

# FleetGraph integration (optional)
VITE_FLEETGRAPH_API_URL=http://localhost:8787
VITE_FLEETGRAPH_API_KEY=
